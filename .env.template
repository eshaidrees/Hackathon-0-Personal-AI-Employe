# AI Employee Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ===========================================
# CLAUDE/QWEN CODE CONFIGURATION
# ===========================================
# Command to run Claude/Qwen Code (default: claude)
CLAUDE_COMMAND=claude

# Maximum iterations for Claude/Qwen to complete a task
MAX_CLAUDE_ITERATIONS=10

# ===========================================
# GMAIL API CONFIGURATION
# ===========================================
# Path to Gmail OAuth credentials file (download from Google Cloud Console)
# Get credentials from: https://console.cloud.google.com/apis/credentials
GMAIL_CREDENTIALS_PATH=credentials.json

# Path to Gmail OAuth token file (auto-generated after OAuth)
GMAIL_TOKEN_PATH=token.json

# ===========================================
# LINKEDIN CONFIGURATION
# ===========================================
# LinkedIn email (optional - for auto-login)
LINKEDIN_EMAIL=

# LinkedIn password (optional - for auto-login)
LINKEDIN_PASSWORD=

# Path to LinkedIn browser session storage
LINKEDIN_SESSION_PATH=./linkedin_session

# Keywords for LinkedIn notifications (comma-separated)
LINKEDIN_KEYWORDS=message,connection,job,post

# ===========================================
# WHATSAPP CONFIGURATION
# ===========================================
# Path to WhatsApp session storage
WHATSAPP_SESSION_PATH=./whatsapp_session

# Priority keywords for WhatsApp (comma-separated)
WHATSAPP_KEYWORDS=urgent,asap,invoice,payment,help

# ===========================================
# ODOO ERP CONFIGURATION (Gold Tier)
# ===========================================
# Odoo instance URL (local or cloud)
# For local: http://localhost:8069
# For cloud: https://your-instance.odoo.com
ODOO_URL=http://localhost:8069

# Odoo database name
ODOO_DATABASE=odoo

# Odoo username (usually 'admin')
ODOO_USERNAME=admin

# Odoo password or API key
# For API key: Go to Settings > Users > Your User > Preferences
ODOO_PASSWORD=

# ===========================================
# FACEBOOK CONFIGURATION (Gold Tier)
# ===========================================
# Facebook login email
FACEBOOK_EMAIL=

# Facebook login password
FACEBOOK_PASSWORD=

# Path to Facebook browser session storage
FACEBOOK_SESSION_PATH=./facebook_session

# Facebook Page ID (for business pages - optional)
FACEBOOK_PAGE_ID=

# ===========================================
# INSTAGRAM CONFIGURATION (Gold Tier)
# ===========================================
# Instagram login email
INSTAGRAM_EMAIL=

# Instagram login password
INSTAGRAM_PASSWORD=

# Path to Instagram browser session storage
INSTAGRAM_SESSION_PATH=./instagram_session

# Instagram Business Account ID (optional - for API access)
INSTAGRAM_ACCOUNT_ID=

# ===========================================
# TWITTER/X CONFIGURATION (Gold Tier)
# ===========================================
# Twitter/X login email (for browser automation)
TWITTER_EMAIL=

# Twitter/X username (handle)
TWITTER_USERNAME=

# Twitter/X login password (for browser automation)
TWITTER_PASSWORD=

# Path to Twitter browser session storage (for Playwright)
TWITTER_SESSION_PATH=./twitter_session

# Twitter API v2 Credentials (for official API - Recommended)
# Get from: https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ===========================================
# SOCIAL MEDIA KEYWORDS (Gold Tier)
# ===========================================
# Keywords for Facebook/Instagram notifications
SOCIAL_KEYWORDS=message,comment,share,mention,urgent

# Keywords for Twitter/X notifications
TWITTER_KEYWORDS=mention,message,DM,urgent,question

# Keywords for LinkedIn notifications
LINKEDIN_KEYWORDS=message,connection,job,post,opportunity

# ===========================================
# META DEVELOPER APP CONFIGURATION (Optional - Graph API)
# ===========================================
# For advanced Facebook/Instagram API access
# Get from: https://developers.facebook.com/apps/
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_PAGE_ACCESS_TOKEN=

# ===========================================
# LINKEDIN API CONFIGURATION (Optional)
# ===========================================
# For advanced LinkedIn API access
# Get from: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_COMPANY_ID=

# ===========================================
# BANKING/API CONFIGURATION
# ===========================================
# Bank API token (if using automated banking)
BANK_API_TOKEN=

# ===========================================
# OPERATION MODE
# ===========================================
# Dry run mode: true/false
# When true, no actual external actions are taken
DRY_RUN=true

# ===========================================
# LOGGING (Gold Tier)
# ===========================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log retention days (Gold Tier)
LOG_RETENTION_DAYS=90

# ===========================================
# VAULT PATH
# ===========================================
# Absolute path to your Obsidian vault
VAULT_PATH=

# ===========================================
# POSTING CONFIGURATION
# ===========================================
# Require approval for LinkedIn posts
POST_APPROVAL_REQUIRED=true

# Require approval for Facebook/Instagram posts
SOCIAL_POST_APPROVAL_REQUIRED=true

# Require approval for Twitter/X posts
TWITTER_POST_APPROVAL_REQUIRED=true

# ===========================================
# ERROR RECOVERY (Gold Tier)
# ===========================================
# Enable circuit breaker pattern
CIRCUIT_BREAKER_ENABLED=true

# Circuit breaker failure threshold
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# Circuit breaker recovery timeout (seconds)
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# ===========================================
# SCHEDULING CONFIGURATION
# ===========================================
# Daily briefing time (24-hour format)
DAILY_BRIEFING_TIME=08:00

# Weekly audit day (Monday-Sunday)
WEEKLY_AUDIT_DAY=Monday

# Weekly audit time (24-hour format)
WEEKLY_AUDIT_TIME=07:00

# ===========================================
# RATE LIMITING (Gold Tier)
# ===========================================
# Maximum requests per minute for APIs
API_RATE_LIMIT=60

# Maximum posts per day per platform
MAX_POSTS_PER_DAY=10

# Delay between social media actions (seconds)
SOCIAL_MEDIA_DELAY=5
