# AI Employee Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ===========================================
# CLAUDE/QWEN CODE CONFIGURATION
# ===========================================
# Command to run Claude/Qwen Code (default: claude)
CLAUDE_COMMAND=claude

# Maximum iterations for Claude/Qwen to complete a task
MAX_CLAUDE_ITERATIONS=10

# ===========================================
# GMAIL API CONFIGURATION
# ===========================================
# Path to Gmail OAuth credentials file (download from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=credentials.json

# Path to Gmail token file (auto-generated after OAuth)
GMAIL_TOKEN_PATH=token.json

# ===========================================
# LINKEDIN CONFIGURATION
# ===========================================
# LinkedIn email (optional - for auto-login)
LINKEDIN_EMAIL=

# LinkedIn password (optional - for auto-login)
LINKEDIN_PASSWORD=

# Path to LinkedIn browser session storage
LINKEDIN_SESSION_PATH=./linkedin_session

# Keywords for LinkedIn notifications (comma-separated)
LINKEDIN_KEYWORDS=message,connection,job,post

# ===========================================
# WHATSAPP CONFIGURATION
# ===========================================
# Path to WhatsApp session storage
WHATSAPP_SESSION_PATH=./whatsapp_session

# Priority keywords for WhatsApp (comma-separated)
WHATSAPP_KEYWORDS=urgent,asap,invoice,payment,help

# ===========================================
# BANKING/API CONFIGURATION
# ===========================================
# Bank API token (if using automated banking)
BANK_API_TOKEN=

# ===========================================
# OPERATION MODE
# ===========================================
# Dry run mode: true/false
# When true, no actual external actions are taken
DRY_RUN=true

# ===========================================
# LOGGING
# ===========================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ===========================================
# VAULT PATH
# ===========================================
# Absolute path to your Obsidian vault
VAULT_PATH=

# ===========================================
# POSTING CONFIGURATION
# ===========================================
# Require approval for LinkedIn posts
POST_APPROVAL_REQUIRED=true
